# =============================================================================
# Caddy Control Panel - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running docker compose up
#
# TWO MODES:
#   Domain mode:  docker compose up -d --build
#                 Panel at https://panel.example.com (Caddy HTTPS)
#
#   Local mode:   docker compose -f docker-compose.local.yml up -d --build
#                 Panel at http://<VM-IP>:8080 (no domain needed)

# --- REQUIRED ---

# Secret key for JWT tokens and encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Admin credentials (created on first boot)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Database password
DB_PASSWORD=

# Redis password
REDIS_PASSWORD=

# --- PANEL (domain mode only) ---

# Domain for the panel itself (used by Caddy for HTTPS)
# Set to "localhost" or leave empty for local mode
PANEL_DOMAIN=panel.example.com

# Email for ACME/Let's Encrypt certificates
ACME_EMAIL=admin@example.com

# --- PANEL (local mode only) ---

# Port for the panel UI (default: 8080)
PANEL_PORT=8080

# --- GENERAL ---

# Environment: production or development
ENVIRONMENT=production

# Log level: debug, info, warning, error
LOG_LEVEL=info

# --- DATABASE ---

DB_USER=caddy
DB_NAME=caddypanel

# --- CLOUDFLARE (optional) ---

# API token with Zone:Read, DNS:Edit, Zone Settings:Edit permissions
CLOUDFLARE_API_TOKEN=

# --- SECURITY (optional) ---

# Restrict panel access to these CIDRs (comma-separated, empty = allow all)
# Example: 203.0.113.0/24,198.51.100.5/32
ALLOWED_IPS=
