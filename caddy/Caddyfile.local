{
	email {$ACME_EMAIL}
	admin localhost:2019

	servers {
		timeouts {
			read_body 30s
			read_header 10s
			write 60s
			idle 120s
		}
		max_header_size 16KB
	}
}

# No panel site block — panel is served by the frontend container directly.
# Caddy only handles managed domains (injected via Admin API).
# Admin API on localhost:2019 only — backend reaches it via host.docker.internal.
